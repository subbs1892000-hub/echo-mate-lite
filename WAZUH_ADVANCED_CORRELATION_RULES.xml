<group name="soc_lab_advanced_correlation,">

  <!-- Successful Windows login after repeated failures -->
  <rule id="100400" level="14" frequency="1" timeframe="300">
    <if_matched_sid>100100</if_matched_sid>
    <same_field>win.eventdata.ipAddress</same_field>
    <field name="win.system.channel">^Security$</field>
    <field name="win.system.eventID">^4624$</field>
    <description>Successful Windows logon after repeated failed attempts from $(win.eventdata.ipAddress)</description>
    <group>windows,authentication,valid_accounts,attack,correlation,</group>
    <mitre>
      <id>T1078</id>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- Suspicious PowerShell with download behavior -->
  <rule id="100401" level="14">
    <if_sid>100120</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(downloadstring|downloadfile|http://|https://|invoke-webrequest|iwr )</field>
    <description>High-confidence malicious PowerShell with download behavior detected</description>
    <group>windows,sysmon,powershell,attack,correlation,</group>
    <mitre>
      <id>T1059.001</id>
      <id>T1105</id>
    </mitre>
  </rule>

  <!-- Linux SSH brute force followed by successful authentication -->
  <rule id="100402" level="14" frequency="1" timeframe="300">
    <if_matched_sid>100130</if_matched_sid>
    <same_srcip />
    <match>Accepted password</match>
    <description>Successful Linux SSH authentication after repeated failures from $(srcip)</description>
    <group>linux,ssh,valid_accounts,attack,correlation,</group>
    <mitre>
      <id>T1078</id>
      <id>T1110</id>
    </mitre>
  </rule>

</group>
