<ossec_config>

  <syscheck>
    <disabled>no</disabled>
    <frequency>43200</frequency>
    <scan_on_start>yes</scan_on_start>

    <!-- Linux real-time monitoring -->
    <directories realtime="yes" check_all="yes">/etc</directories>
    <directories realtime="yes" check_all="yes">/usr/bin</directories>
    <directories realtime="yes" check_all="yes">/var/www</directories>

    <!-- Windows real-time monitoring -->
    <directories realtime="yes" check_all="yes">C:\LabFiles</directories>
    <directories realtime="yes" check_all="yes">C:\Windows\System32</directories>

    <!-- Windows registry monitoring example -->
    <windows_registry realtime="yes">HKEY_LOCAL_MACHINE\Software\Microsoft\Windows\CurrentVersion\Run</windows_registry>
    <windows_registry realtime="yes">HKEY_LOCAL_MACHINE\System\CurrentControlSet\Services</windows_registry>

    <!-- Reduce noise -->
    <ignore>/etc/mtab</ignore>
    <ignore>/etc/hosts.deny</ignore>
    <ignore type="sregex">.log$|.swp$|.tmp$</ignore>
  </syscheck>

</ossec_config>
